        { "expr": "sum by (reason) (rate(anti_ddos_xdp_packets_total{action=\"1\"}[1m]))", "legendFormat": "reason {{reason}}", "refId": "A" }
      ],
      "title": "Drops by reason",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
