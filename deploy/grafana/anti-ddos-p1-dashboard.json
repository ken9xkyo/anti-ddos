      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "id": 5,
      "targets": [
        { "expr": "sum by (service_id, output_interface) (rate(anti_ddos_redirected_packets_total[1m]))", "legendFormat": "svc {{service_id}} if {{output_interface}}", "refId": "A" },
        { "expr": "sum by (service_id, output_interface) (rate(anti_ddos_redirect_errors_total[1m]))", "legendFormat": "redirect error svc {{service_id}}", "refId": "B" }
