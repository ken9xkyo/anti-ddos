        { "expr": "sum(rate(anti_ddos_xdp_packets_total{proto=\"6\",tcp_syn=\"1\",action=~\"0|1|6\"}[1m]))", "legendFormat": "syn cps", "refId": "A" }
      ],
      "title": "TCP SYN CPS",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
