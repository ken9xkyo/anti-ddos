COMPOSE_PROJECT_NAME=anti-ddos

# Image tags are pinned for repeatable lab deployment. Update deliberately.
POSTGRES_IMAGE=postgres:16.9-alpine3.22
GO_IMAGE=golang:1.22.12-bookworm
CONTROL_RUNTIME_IMAGE=debian:bookworm-slim
CONTROL_API_IMAGE=anti-ddos/control-api:local
NODE_IMAGE=node:22.22.1-alpine3.22
NGINX_IMAGE=nginx:1.30.1-alpine3.23
ADMIN_DASHBOARD_IMAGE=anti-ddos/admin-dashboard:local
PROMETHEUS_IMAGE=prom/prometheus:v3.5.2
GRAFANA_IMAGE=grafana/grafana:12.4.3-security-02

# Host bind ports. Defaults bind only to loopback in docker-compose.yml.
POSTGRES_PORT=5432
CONTROL_API_PORT=8080
ADMIN_DASHBOARD_PORT=8088
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000

# Lab-only placeholders. Replace in local .env and do not commit real secrets.
POSTGRES_DB=anti_ddos
POSTGRES_USER=anti_ddos
POSTGRES_PASSWORD=change-me-postgres-lab-only
ANTI_DDOS_AGENT_SHARED_TOKEN=change-me-agent-shared-token
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me-grafana-admin

# Runtime tuning.
ANTI_DDOS_SESSION_TTL=12h
ANTI_DDOS_AGENT_STALE_AFTER=30s
ANTI_DDOS_EVENT_SAMPLE_DENOM=1
PROMETHEUS_RETENTION=15d
